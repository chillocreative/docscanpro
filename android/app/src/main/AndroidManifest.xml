<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="com.android.vending.BILLING" />

    <!-- Storage: the app captures via the camera plugin and writes
         exclusively to its own app-specific directory through
         path_provider's getExternalStorageDirectory()
         (= Android's getExternalFilesDir()). That directory has not
         required any storage permission since API 19 (KitKat), and our
         minSdk is 24, so we declare zero storage permissions.

         The two `tools:node="remove"` entries below strip permissions
         that camera_android_camerax merges in defensively (and the
         READ_EXTERNAL_STORAGE that the build system auto-implies from
         WRITE_EXTERNAL_STORAGE). Without these removes, Play Console's
         Photo & Video Permissions policy fires because Google treats
         the legacy storage pair as broad photo/video access regardless
         of any maxSdkVersion bound. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        tools:node="remove" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        tools:node="remove" />

    <application
        android:label="DocScan Pro"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!-- AdMob app ID — production publisher
             ca-app-pub-3464451429907034. Must match
             AdIds.prodAppIdAndroid in lib/core/constants/ad_ids.dart;
             the SDK will refuse to initialise if they diverge. -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3464451429907034~4744178919" />
        <!-- Pre-download every ML Kit text recognition model the app
             can switch to. Without this, models download lazily on
             first use, which means a user's first OCR run on Japanese
             (etc.) blocks for several seconds while Play services
             fetches the model. -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="ocr,ocr_chinese,ocr_devanagari,ocr_japanese,ocr_korean" />
    </application>
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
